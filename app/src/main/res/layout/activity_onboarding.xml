<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSkip"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="16dp"
        android:text="@string/onboarding_skip"
        android:textColor="@color/on_surface_variant" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="48dp">

        <LinearLayout
            android:id="@+id/dotsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <LinearLayout
            android:id="@+id/consentContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="24dp">

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/checkDisclaimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/consent_check_1"
                android:textAppearance="@style/TextAppearance.IADerm.BodySmall"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/checkPrivacy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/consent_check_2"
                android:textAppearance="@style/TextAppearance.IADerm.BodySmall"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/checkLocal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/consent_check_3"
                android:textAppearance="@style/TextAppearance.IADerm.BodySmall"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReadPrivacy"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/consent_read_privacy"
                android:textSize="12sp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_next"
            style="@style/Widget.IADerm.Button.Primary"
            android:padding="16dp" />
    </LinearLayout>
</LinearLayout>
