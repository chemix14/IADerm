<?xml version="1.0" encoding="utf-8"?>
<!-- Single onboarding page (used inside ViewPager2) -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:paddingStart="32dp"
    android:paddingEnd="32dp">

    <!-- Illustration placeholder (replace with Lottie or image) -->
    <ImageView
        android:id="@+id/imgIllustration"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:scaleType="fitCenter"
        android:layout_marginBottom="32dp"
        android:importantForAccessibility="no" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.IADerm.Headline"
        android:textColor="@color/on_background"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Description -->
    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.IADerm.Body"
        android:textColor="@color/on_surface_variant"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4" />

</LinearLayout>
