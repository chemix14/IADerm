<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:paddingBottom="120dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Greeting -->
        <TextView
            android:id="@+id/tvGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_greeting"
            android:textAppearance="@style/TextAppearance.IADerm.Headline"
            android:textSize="28sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_skin_today"
            android:textAppearance="@style/TextAppearance.IADerm.Body"
            android:layout_marginBottom="24dp" />

        <!-- Last Analysis Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardLastAnalysis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.IADerm.Card"
            app:cardBackgroundColor="@color/primary_container"
            app:strokeWidth="0dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <View
                        android:id="@+id/viewSeverityDot"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/bg_indicator_badge"
                        android:backgroundTint="@color/success"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/tvLastAnalysisLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/home_last_analysis"
                        android:textAppearance="@style/TextAppearance.IADerm.Label"
                        android:textColor="@color/on_primary_container" />


                </LinearLayout>

                <TextView
                    android:id="@+id/tvLastAnalysisDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.IADerm.BodySmall"
                    android:textColor="@color/on_primary_container"
                    tools:text="Hace 3 días — Leve" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressScore"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:progress="42"
                    app:trackThickness="10dp"
                    app:trackCornerRadius="5dp"
                    app:indicatorColor="@color/primary"
                    app:trackColor="@color/on_primary" />

                <TextView
                    android:id="@+id/tvScoreLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.IADerm.Caption"
                    android:textColor="@color/on_primary_container"
                    android:layout_marginTop="8dp"
                    tools:text="Índice de Rojez: 42/100" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnViewDetails"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_view_details"
                    android:layout_marginTop="16dp"
                    app:icon="@android:drawable/ic_menu_search" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Quick Actions Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_quick_actions"
            android:textAppearance="@style/TextAppearance.IADerm.Label"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <!-- Quick Action Cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHistory"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Widget.IADerm.Card"
                app:cardBackgroundColor="@color/secondary_container"
                app:strokeWidth="0dp"
                android:layout_marginEnd="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp">



                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/nav_history"
                        android:textAppearance="@style/TextAppearance.IADerm.Label"
                        android:textColor="@color/on_secondary_container"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ver tu evolución"
                        android:textSize="11sp"
                        android:textColor="@color/on_secondary_container"
                        android:alpha="0.7"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTriggers"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                style="@style/Widget.IADerm.Card"
                app:cardBackgroundColor="@color/tertiary_container"
                app:strokeWidth="0dp"
                android:layout_marginStart="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp">



                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/nav_triggers"
                        android:textAppearance="@style/TextAppearance.IADerm.Label"
                        android:textColor="@color/on_tertiary_container"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Registrar factores"
                        android:textSize="11sp"
                        android:textColor="@color/on_tertiary_container"
                        android:alpha="0.7"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Tip of the Day Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.IADerm.Card"
            app:cardBackgroundColor="@color/surface_variant"
            app:strokeWidth="0dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/home_tip_title"
                        android:textAppearance="@style/TextAppearance.IADerm.Label"
                        android:textColor="@color/on_surface_variant" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Toca para otro →"
                        android:textSize="11sp"
                        android:textColor="@color/on_surface_variant"
                        android:alpha="0.6" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvTipCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/primary"
                    android:layout_marginBottom="8dp"
                    tools:text="☀️ Protección Solar" />

                <TextView
                    android:id="@+id/tvTipContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/home_tip_content"
                    android:textAppearance="@style/TextAppearance.IADerm.BodySmall"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Disclaimer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/disclaimer_short"
            android:textAppearance="@style/TextAppearance.IADerm.Disclaimer"
            android:gravity="center"
            android:alpha="0.6" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
