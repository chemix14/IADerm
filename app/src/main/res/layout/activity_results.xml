<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/results_title"
            app:titleCentered="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@android:drawable/ic_menu_revert"
                app:iconTint="@color/on_background"
                android:contentDescription="@string/cd_back" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginEnd="16dp"
                app:icon="@android:drawable/ic_menu_save"
                app:iconTint="@color/primary"
                android:contentDescription="@string/results_save" />
        </com.google.android.material.appbar.MaterialToolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:clipToPadding="false"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Suggestion to complete medical profile (Will be hidden if already done) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSuggestProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.IADerm.Card"
                app:cardBackgroundColor="@color/tertiary_container"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📝 Mejora tu diagnóstico"
                        android:textAppearance="@style/TextAppearance.IADerm.Label"
                        android:textColor="@color/on_tertiary_container"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Completa tu perfil clínico en 1 minuto para que nuestra IA especializada entienda tu contexto y te brinde recomendaciones exactas."
                        android:textAppearance="@style/TextAppearance.IADerm.BodySmall"
                        android:textColor="@color/on_tertiary_container"
                        android:layout_marginBottom="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGoToProfile"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Completar Perfil" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- User Analyzed Image -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="24dp">
                
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivAnalyzedPhoto"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                    android:background="@color/surface_variant" />
                    
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔒 Procesado localmente. 100% Privado."
                    android:textAppearance="@style/TextAppearance.IADerm.BodySmall"
                    android:textColor="@color/success"
                    android:layout_marginTop="8dp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Score Circular Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.IADerm.Card"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="32dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/results_redness_index"
                        android:textAppearance="@style/TextAppearance.IADerm.Label"
                        android:layout_marginBottom="16dp" />

                    <FrameLayout
                        android:layout_width="160dp"
                        android:layout_height="160dp">

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/progressScore"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:progress="0"
                            android:max="100"
                            app:indicatorSize="160dp"
                            app:trackThickness="12dp"
                            app:trackCornerRadius="6dp"
                            app:indicatorColor="@color/primary"
                            app:trackColor="@color/surface_variant" />

                        <TextView
                            android:id="@+id/tvScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:textAppearance="@style/TextAppearance.IADerm.Headline"
                            android:textSize="32sp"
                            tools:text="42/100" />
                    </FrameLayout>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipSeverity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        tools:text="Leve"
                        style="@style/Widget.IADerm.Chip.Severity.Mild" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Diagnostic Details -->
            <TextView
                android:id="@+id/tvDiagnosisLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Diagnóstico"
                android:textAppearance="@style/TextAppearance.IADerm.Label"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.IADerm.Card.Outlined"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvTop3List"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.IADerm.Body"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="12dp"
                        tools:text="1. Acné: 85%" />

                    <TextView
                        android:id="@+id/tvResultDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.IADerm.BodySmall"
                        android:lineSpacingMultiplier="1.4"
                        tools:text="@string/results_desc_mild" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Recommendations -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/results_recommendations"
                android:textAppearance="@style/TextAppearance.IADerm.Label"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.IADerm.Card"
                app:cardBackgroundColor="@color/secondary_container"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvRecommendationList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.IADerm.BodySmall"
                        android:lineSpacingMultiplier="1.4"
                        android:textColor="@color/on_secondary_container"
                        tools:text="- Usar protector solar\n- Hidratar la piel" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAIChat"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Hablar con Asistente IA"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_marginTop="20dp"
                        app:icon="@android:drawable/stat_notify_chat" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBookAppointment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Encuentra a un especialista"
                        style="@style/Widget.IADerm.Button.Primary"
                        android:layout_marginTop="12dp"
                        app:icon="@android:drawable/ic_menu_mapmode" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Disclaimer -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/disclaimer_short"
                android:textAppearance="@style/TextAppearance.IADerm.Disclaimer"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
